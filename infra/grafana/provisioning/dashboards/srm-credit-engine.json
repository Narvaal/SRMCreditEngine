{
  "uid": "srm-credit-engine",
  "title": "SRM Credit Engine",
  "tags": ["srm", "provisionado"],
  "timezone": "browser",
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 41,
  "panels": [
    {
      "type": "row",
      "title": "Negócio",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Liquidações (acumulado)",
      "description": "Total desde o último boot do backend (contador Prometheus). increase() por janela subestimaria: a série nasce já em 1 no primeiro incremento.",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(srm_liquidacoes_total)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "noValue": "0",
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "options": { "graphMode": "none", "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Estornos (acumulado)",
      "description": "Total desde o último boot do backend (contador Prometheus).",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(srm_estornos_total)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "noValue": "0",
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "options": { "graphMode": "none", "colorMode": "value" }
    },
    {
      "type": "timeseries",
      "title": "Operações por minuto",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(srm_liquidacoes_total[$__rate_interval])) * 60",
          "legendFormat": "liquidações/min"
        },
        {
          "refId": "B",
          "expr": "sum(rate(srm_estornos_total[$__rate_interval])) * 60",
          "legendFormat": "estornos/min"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 }, "min": 0 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Valor liquidado por minuto (moeda de pagamento)",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (moeda) (rate(srm_liquidacoes_valor_total[$__rate_interval])) * 60",
          "legendFormat": "{{moeda}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 }, "min": 0, "decimals": 2 },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "API HTTP",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Requisições/s por rota",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{uri=~\"/api/.*\"}[$__rate_interval]))",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 }, "min": 0, "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Latência p95 por rota",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{uri=~\"/api/.*\"}[$__rate_interval])))",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 }, "min": 0, "unit": "s" },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Erros 4xx/5xx por minuto",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{status=~\"4..|5..\"}[$__rate_interval])) * 60",
          "legendFormat": "HTTP {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "min": 0,
          "noValue": "0",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Resiliência — provider de câmbio (fxProvider)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Circuit breaker — estado atual",
      "gridPos": { "h": 7, "w": 4, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(resilience4j_circuitbreaker_state{name=\"fxProvider\",state=\"closed\"}) * 1 + sum(resilience4j_circuitbreaker_state{name=\"fxProvider\",state=\"half_open\"}) * 2 + sum(resilience4j_circuitbreaker_state{name=\"fxProvider\",state=\"open\"}) * 3",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "CLOSED", "color": "green", "index": 0 },
                "2": { "text": "HALF-OPEN", "color": "orange", "index": 1 },
                "3": { "text": "OPEN", "color": "red", "index": 2 }
              }
            }
          ],
          "noValue": "sem dados"
        },
        "overrides": []
      },
      "options": { "graphMode": "none", "colorMode": "background" }
    },
    {
      "type": "state-timeline",
      "title": "Circuit breaker — estado ao longo do tempo",
      "gridPos": { "h": 7, "w": 8, "x": 4, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(resilience4j_circuitbreaker_state{name=\"fxProvider\",state=\"closed\"}) * 1 + sum(resilience4j_circuitbreaker_state{name=\"fxProvider\",state=\"half_open\"}) * 2 + sum(resilience4j_circuitbreaker_state{name=\"fxProvider\",state=\"open\"}) * 3",
          "legendFormat": "fxProvider"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "CLOSED", "color": "green", "index": 0 },
                "2": { "text": "HALF-OPEN", "color": "orange", "index": 1 },
                "3": { "text": "OPEN", "color": "red", "index": 2 }
              }
            }
          ],
          "custom": { "fillOpacity": 70 }
        },
        "overrides": []
      },
      "options": { "showValue": "auto", "legend": { "showLegend": false } }
    },
    {
      "type": "timeseries",
      "title": "Failure rate (janela do CB)",
      "gridPos": { "h": 7, "w": 4, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "resilience4j_circuitbreaker_failure_rate{name=\"fxProvider\"}",
          "legendFormat": "failure rate %"
        }
      ],
      "description": "-1 = janela ainda sem o mínimo de chamadas (4) pra calcular a taxa.",
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 }, "unit": "percent", "max": 100 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Retries por minuto",
      "gridPos": { "h": 7, "w": 4, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind) (rate(resilience4j_retry_calls_total{name=\"fxProvider\"}[$__rate_interval])) * 60",
          "legendFormat": "{{kind}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 }, "min": 0 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Chamadas ao provider por minuto",
      "gridPos": { "h": 7, "w": 4, "x": 20, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind) (rate(resilience4j_circuitbreaker_calls_seconds_count{name=\"fxProvider\"}[$__rate_interval])) * 60",
          "legendFormat": "{{kind}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 }, "min": 0 },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Runtime — JVM e banco",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Heap usado vs. máximo",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "usado"
        },
        {
          "refId": "B",
          "expr": "sum(jvm_memory_max_bytes{area=\"heap\"})",
          "legendFormat": "máximo"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 }, "min": 0, "unit": "bytes" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "máximo" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "Pausa de GC (tempo/s)",
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(jvm_gc_pause_seconds_sum[$__rate_interval]))",
          "legendFormat": "pausa de GC"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 }, "min": 0, "unit": "s" },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "CPU",
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "process_cpu_usage{application=\"srm-credit-engine\"}",
          "legendFormat": "processo"
        },
        {
          "refId": "B",
          "expr": "system_cpu_usage{application=\"srm-credit-engine\"}",
          "legendFormat": "sistema"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Pool de conexões (HikariCP)",
      "description": "checkouts/s vem do timer de uso — o gauge de ativas quase sempre lê 0 no scrape de 15s porque as queries locais duram ~1ms. Threads aguardando > 0 é o sinal real de pool saturado.",
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(hikaricp_connections_usage_seconds_count[$__rate_interval]))",
          "legendFormat": "checkouts/s"
        },
        {
          "refId": "B",
          "expr": "hikaricp_connections_active{application=\"srm-credit-engine\"}",
          "legendFormat": "ativas (no scrape)"
        },
        {
          "refId": "C",
          "expr": "hikaricp_connections_pending{application=\"srm-credit-engine\"}",
          "legendFormat": "aguardando"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 }, "min": 0 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "checkouts/s" },
            "properties": [{ "id": "custom.axisPlacement", "value": "right" }]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    }
  ]
}
