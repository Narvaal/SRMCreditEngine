set -e

# Só unit/slice (*Test) — os testes de integração (*IT, Testcontainers) rodam no CI:
# o Docker Engine deste ambiente de dev é incompatível com o probe do Testcontainers 1.21.x,
# e um hook que sempre falha vira um hook sempre pulado com --no-verify (perdendo inclusive
# os testes de frontend). Detalhe documentado no README.
echo "==> Rodando testes do backend (JUnit — unit/slice; *IT rodam no CI)"
(cd backend && ./gradlew test -q --tests '*Test')

echo "==> Rodando testes do frontend"
(cd frontend && npm test)
